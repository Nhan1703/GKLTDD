PORT=3000
JWT_SECRET=fellow4u_dev_secret_change_in_production

# SQL Server — local (SSMS)
# DB_SERVER=localhost\SQLEXPRESS

# SQL Server — GearHost (Render / Docker: chỉ hostname, không \SQLEXPRESS)
# DB_SERVER=den1.mssql1.gear.host
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=fellow4u_db
DB_USER=sa
DB_PASSWORD=123123

# Windows Authentication (đăng nhập Windows, không cần sa/password):
# DB_USE_WINDOWS_AUTH=true

# SSMS: Encrypt = Mandatory, Trust Server Certificate = checked
DB_ENCRYPT=true
DB_TRUST_CERT=true
